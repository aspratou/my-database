---
import type { ContentEntry } from "../../types";
import FormattedDate from "./FormattedDate.astro";

interface Props {
    entry: ContentEntry;
}

const { entry } = Astro.props;
const { collection, data } = entry;
const { pubDate, updatedDate, author } = data;

const displayDate = updatedDate ?? pubDate;
---

<div class="flex flex-wrap items-center gap-4 text-sm sm:gap-6">
    {
        author && (
            <div class="flex items-center gap-2">
                {author.avatar && (
                    <div class="h-9 w-9 overflow-hidden rounded-full bg-neutral-100 dark:bg-neutral-800">
                        <img
                            src={author.avatar.src}
                            alt={author.avatar.alt || author.name}
                            loading="eager"
                            class="h-full w-full object-cover"
                        />
                    </div>
                )}
                <div class="flex flex-col">
                    <span class="font-medium text-neutral-800 dark:text-neutral-200">
                        {author.name}
                    </span>
                    {author.handle && (
                        <span class="text-xs text-neutral-500 dark:text-neutral-400">
                            {author.handle}
                        </span>
                    )}
                </div>
            </div>
        )
    }

    <div class="flex flex-col gap-0.5 text-neutral-500 dark:text-neutral-400">
        <span class="text-xs uppercase tracking-wider">Published</span>
        <FormattedDate date={displayDate} />
    </div>
</div>