---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="お問い合わせ">
  <div style="max-width: 768px; margin: 0 auto !important; padding: 60px 24px !important; box-sizing: border-box;">
    
    <h1 style="font-size: 1.875rem; font-weight: 700; line-height: 1.25; margin-bottom: 2rem; color: inherit;">
      お問い合わせ
    </h1>
    
    <div style="font-size: 1rem; line-height: 1.75; color: inherit; margin-bottom: 2.5rem;">
      <p style="margin: 0;">当ブログに関するお問い合わせやご意見・ご感想は、以下の公式お問い合わせフォームよりお願いいたします。</p>
    </div>

    <div style="background-color: rgba(156, 163, 175, 0.05); border: 1px solid rgba(156, 163, 175, 0.2); border-radius: 0.75rem; padding: 40px 24px; text-align: center; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
      <div style="font-size: 3rem; margin-bottom: 1rem;">✉️</div>
      <h2 style="font-size: 1.25rem; font-weight: 600; margin-bottom: 0.5rem; color: inherit;">Google フォームでお問い合わせ</h2>
      <p style="font-size: 0.875rem; opacity: 0.8; margin-bottom: 2rem;">※クリックすると、安全な外部の入力画面（Googleフォーム）が新しいタブで開きます。</p>
      
      <a 
        href="https://docs.google.com/forms/d/e/1FAIpQLScC2W75bvzyQEtZf1Ht8kJv0oZfP_AgkNaHiT9h5SKJG_Xpvw/viewform?usp=sf_link" 
        target="_blank" 
        rel="noopener noreferrer" 
        style="display: inline-block; background-color: #171717; color: #ffffff; font-weight: 600; padding: 0.75rem 2.5rem; border-radius: 0.375rem; text-decoration: none; font-size: 0.95rem; transition: background-color 0.2s;"
        onmouseover="this.style.backgroundColor='#404040'"
        onmouseout="this.style.backgroundColor='#171717'"
      >
        お問い合わせフォームを開く
      </a>
    </div>

  </div>
</BaseLayout>