---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="お問い合わせ">
  <div style="max-width: 768px; margin: 0 auto !important; padding: 60px 24px !important; box-sizing: border-box;">
    
    <h1 style="font-size: 1.875rem; font-weight: 700; line-height: 1.25; margin-bottom: 2rem; color: inherit;">
      お問い合わせ
    </h1>
    
    <div style="font-size: 1rem; line-height: 1.75; color: inherit; margin-bottom: 2.5rem;">
      <p style="margin: 0;">当ブログに関するお問い合わせは、以下のフォームよりお願いいたします。</p>
    </div>

    <div style="width: 100%; overflow: hidden; background-color: transparent;">
      <iframe 
        src="https://docs.google.com/forms/d/e/1FAIpQLScC2W75bvzyQEtZf1Ht8kJv0oZfP_AgkNaHiT9h5SKJG_Xpvw/viewform?embedded=true" 
        width="100%" 
        height="900" 
        style="border: none; max-width: 100%; min-width: 100%;"
        loading="lazy"
      >
        読み込んでいます…
      </iframe>
    </div>

  </div>
</BaseLayout>