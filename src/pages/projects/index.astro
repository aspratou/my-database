---
import { getCollection } from "astro:content";
import ListLayout from "../../layouts/ListLayout.astro";
import { attachMeta } from "../../utils/meta";

// 💡 内部の取得先(コレクション名)は "projects" のまま、変数名を「activities」に適切に修正
const activities = (await getCollection("projects", ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .map((p) => attachMeta(p));
---

<ListLayout
    title="Activity" // 💡 画面上のタイトルを「Projects」から「Activity」に統合
    description="A collection of my activities." // 💡 説明文も適切に修正
    ogImage="https://res.cloudinary.com/dellp9a4z/image/upload/v1756758388/og-projects_mj7lcc.png"
    entries={activities} // 💡 渡す変数名も変更
/>