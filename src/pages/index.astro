---
import { getCollection } from "astro:content";
import Container from "../components/layouts/Container.astro";
import ContentGrid from "../components/layouts/sections/ContentGrid.astro";
import FeaturedContent from "../components/layouts/sections/FeaturedContent.astro";
import EmptyState from "../components/ui/EmptyState.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { attachMeta } from "../utils/meta";

const allDiaries = await getCollection("diary", ({ data }) => !data.draft);
const allBooks = await getCollection("book", ({ data }) => !data.draft);

const sortedPosts = allDiaries.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const sortedBooks = allBooks.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestPosts = sortedPosts.slice(0, 3).map((post) => attachMeta(post));
const latestBooks = sortedBooks
    .slice(0, 2)
    .map((book) => attachMeta(book));

const featured = [...allDiaries, ...allBooks]
    .filter((item) => item.data.featured !== undefined)
    .sort((a, b) => (a.data.featured ?? 0) - (b.data.featured ?? 0));

const hasContent =
    featured.length > 0 || latestPosts.length > 0 || latestBooks.length > 0;
---

<BaseLayout
    title="Rato"
    description="社会システムの解説や言語のニュアンス、ゲームメカニクスまで、日々のアウトプットや探求をまとめる個人データベース。"
>
    <Container class="space-y-24 py-12">
        {
            hasContent ? (
                <>
                    {featured.length > 0 && (
                        <FeaturedContent items={featured} />
                    )}

                    {latestPosts.length > 0 && (
                        <ContentGrid
                            title="Latest Posts"
                            href="/diary"
                            viewAllText="View all posts →"
                            items={latestPosts}
                        />
                    )}

                    {/* 💡 見出し（title）とリンク先、ボタンのテキストを Books 用に適切に修正しました */}
                    {latestBooks.length > 0 && (
                        <ContentGrid
                            title="Latest Books"
                            href="/books"
                            viewAllText="View all books →"
                            items={latestBooks}
                            class="grid grid-cols-1 gap-8 md:grid-cols-2"
                        />
                    )}
                </>
            ) : (
                <EmptyState
                    title="Nothing here yet..."
                    message="Check back soon for new items!"
                />
            )
        }
    </Container>
</BaseLayout>